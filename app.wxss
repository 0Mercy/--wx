page {
  --bg-primary: #0f0f23;
  --bg-secondary: #1a1a2e;
  --bg-card: #16213e;
  --accent: #4e8cff;
  --accent-secondary: #ff6b9d;
  --text-primary: #e8e8f0;
  --text-secondary: #8b8ba7;
  --border: #2a2a4a;
  --danger: #ff4757;
  --success: #2ed573;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}
