.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

/* 上传区域 */
.upload-section {
  margin: 20rpx 0 48rpx;
}

.upload-card {
  background: var(--bg-card);
  border: 3rpx dashed var(--border);
  border-radius: 24rpx;
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: border-color 0.3s;
}

.upload-card:active {
  border-color: var(--accent);
  background: rgba(78, 140, 255, 0.05);
}

.upload-icon {
  font-size: 72rpx;
  color: var(--accent);
  font-weight: 300;
  line-height: 1;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 历史记录 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.section-action {
  font-size: 26rpx;
  color: var(--danger);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 16rpx;
}

.history-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: var(--border);
}

.history-info {
  flex: 1;
  margin-left: 20rpx;
}

.history-date {
  font-size: 26rpx;
  color: var(--text-primary);
}

.history-mode {
  font-size: 22rpx;
  color: var(--accent);
  margin-top: 6rpx;
}

.history-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  opacity: 0.6;
  margin-top: 8rpx;
}
